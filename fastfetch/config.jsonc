{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "display": {
        "separator": " "
    },
    "logo": {
                    "type": "kitty-direct",
                    "source": "~/Pictures/cachyos-linux.png",
                    "height": 22,
                    "width": 62
            },   
    "modules": [
        {
            "type": "os",
            "key": "󰣭 OS",
            "keyColor": "yellow"
        },
        {
            "type": "kernel",
            "key": "├ Kernel",
            "keyColor": "yellow"
        },
        {
            "type": "packages",
            "key": "├󰏖 Packages",
            "keyColor": "yellow"
        },
        {
            "type": "uptime",
            "key": "├󰅐 Uptime",
            "keyColor": "yellow"
        },

    {
            "type": "command",
            "key": "├ Installed",
            "keyColor": "yellow",
            "text": "stat -c %w /home | cut -d' ' -f1",
    },
    {
            "type": "command",
            "key": "├󰃶 Today",
            "shell": "/bin/bash",
            "text": "date +%s | awk '{print strftime(\"%Y-%m-%d\", $1)}'",
        "keyColor": "yellow"
    },
    {
            "type": "command",
            "key": "└󰥕 Age",
            "keyColor": "yellow",
            "text": "echo $(( ($(date +%s) - $(stat -c %W /)) / 86400 )) days ago",
    },
            "break",
        {
            "type": "de",
            "key": "󰟀 DE",
            "keyColor": "blue"
        },
        {
            "type": "wm",
            "key": "├󰧨 Window Manager",
            "keyColor": "blue"
        },
        {
            "type": "lm",
            "key": "├󰧨 Login Manager",
            "keyColor": "blue"
        },
        {
            "type": "wmtheme",
            "key": "├󰉼 System Theme",
            "keyColor": "blue"
        },
        {
            "type": "icons",
            "key": "└󰸉 System Icons",
            "keyColor": "blue"
        },
            "break",
        {
            "type": "host",
            "key": "󰇅 PC",
            "keyColor": "green"
        },
        {
            "type": "cpu",
            "key": "├󰻠 CPU",
            "keyColor": "green",
            "temp": false,
            "freqNdigits": 1
        },
        {
            "type": "memory",
            "key": "├󰑭 RAM",
            "keyColor": "green"
        },
        {
            "type": "swap",
            "key": "├󰓡 Swap",
            "keyColor": "green"
        },
        {
            "type": "disk",
            "key": "├󰉉 Disk",
            "keyColor": "green"
        },
        {
            "type": "gpu",
            "key": "├󰍛 GPU",
            "keyColor": "green"
        },
        {
            "type": "display",
            "key": "└󰍹 Display(s)",
            "keyColor": "green"
        },
    "break",
  ]
}

